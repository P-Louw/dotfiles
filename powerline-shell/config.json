{
  "segments": [
    "virtual_env",
    "username",
    "hostname",
    "ssh",
    "cwd",
    "git",
    "hg",
    "jobs",
    "newline",
    "root"
  ],
  "mode": "patched",
  "cwd": {
      "max_depth": 2,
      "max_dir_size": 15,
      "full_cwd": true
  },
  "hostname": {
      "colorize": true
  },
  "vcs": {
      "show_symbol": true
  },
  "theme": "gruvbox"
}
